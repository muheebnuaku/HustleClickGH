// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String        @id @default(cuid())
  userId          String        @unique // Auto-generated user ID for login
  fullName        String
  email           String        @unique
  phone           String
  password        String
  image           String?       // Profile image URL or base64
  nationalId      String?
  role            String        @default("user") // user, admin, or manager
  status          String        @default("active") // active, suspended
  emailFlagged    Boolean       @default(false) // true if email from free provider
  balance         Float         @default(0)
  totalEarned     Float         @default(0)
  referralCode    String        @unique
  referredBy      String?
  personalCallCode String?      @unique // Permanent 5-char code for voice calls
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  surveyResponses  SurveyResponse[]
  withdrawals      Withdrawal[]
  referrals        Referral[]       @relation("Referrer")
  referredUsers    Referral[]       @relation("Referred")
  dataSubmissions  DataSubmission[]
  callRecordings   CallRecording[]
}

model Survey {
  id                  String           @id @default(cuid())
  title               String
  description         String
  headerImage         String?          // Optional header image URL/base64 displayed at top of survey
  backgroundImage     String?          // Optional background image URL/base64 displayed behind survey form
  reward              Float            @default(0) // 0 for user surveys, > 0 for admin surveys
  maxRespondents      Int
  currentRespondents  Int              @default(0)
  visibility          String           @default("public")
  status              String           @default("active") // active, expired, paused
  surveyType          String           @default("admin") // admin or user
  shareCode           String?          @unique // Unique code for sharing user surveys
  expiresAt           DateTime
  createdBy           String
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  
  // Relations
  questions           SurveyQuestion[]
  responses           SurveyResponse[]
}

model SurveyQuestion {
  id              String   @id @default(cuid())
  surveyId        String
  questionText    String
  questionType    String   // text, multiple-choice, rating, etc.
  options         String?  // JSON string for options
  required        Boolean  @default(true)
  order           Int
  createdAt       DateTime @default(now())
  
  // Relations
  survey          Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
}

model SurveyResponse {
  id              String   @id @default(cuid())
  surveyId        String
  userId          String
  answers         String   // JSON string of answers
  rewarded        Boolean  @default(false)
  submittedAt     DateTime @default(now())
  
  // Relations
  survey          Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([surveyId, userId])
}

model Withdrawal {
  id              String   @id @default(cuid())
  userId          String
  amount          Float
  paymentMethod   String
  mobileNumber    String
  accountName     String
  status          String   @default("pending") // pending, approved, rejected
  requestedAt     DateTime @default(now())
  processedAt     DateTime?
  processedBy     String?
  notes           String?
  
  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Referral {
  id              String   @id @default(cuid())
  referrerId      String
  referredId      String
  earned          Float    @default(1.0)
  createdAt       DateTime @default(now())

  // Relations
  referrer        User     @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred        User     @relation("Referred", fields: [referredId], references: [id], onDelete: Cascade)

  @@unique([referrerId, referredId])
}

model DataProject {
  id                 String           @id @default(cuid())
  title              String
  description        String
  projectType        String           // voice | video | face
  instructions       String           // step-by-step guide for users
  samplePrompts      String?          // JSON array of prompts/phrases to record
  sampleVideoUrl     String?          // Optional sample video URL (video projects)
  reward             Float            // GH₵ per approved submission
  maxSubmissions        Int
  maxSubmissionsPerUser Int              @default(1)  // how many times each user may submit (1-3)
  currentSubmissions    Int              @default(0)
  status             String           @default("active") // active | paused | completed
  languages          String?          // JSON array e.g. ["English","Twi","Ga"]
  minDurationSecs    Int              @default(3)
  maxDurationSecs    Int              @default(60)
  maxFileSizeMB      Int              @default(25)
  acceptedFormats    String           // JSON array e.g. ["mp3","wav","m4a"]
  // Audio format specs (voice projects)
  audioSampleRate    Int?             // Hz: 16000, 44100, 48000
  audioChannels      Int?             // 1 = mono, 2 = stereo
  audioBitDepth      Int?             // 16 or 32
  recordingType      String?          // "single" | "conversation"
  // Gender quotas (optional)
  malesNeeded        Int?             // how many male submissions needed
  femalesNeeded      Int?             // how many female submissions needed
  malesApproved      Int              @default(0)
  femalesApproved    Int              @default(0)
  expiresAt          DateTime?
  createdBy          String           // admin userId
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  submissions        DataSubmission[]
}

model DataSubmission {
  id              String      @id @default(cuid())
  projectId       String
  userId          String
  fileUrl         String      // Vercel Blob URL or local /uploads/ path in dev
  fileName        String
  fileType        String      // MIME type e.g. audio/mpeg
  fileSizeMB      Float
  durationSecs    Float?
  language        String?
  promptUsed      String?     // Which prompt the user recorded
  gender          String?     // "male" | "female"
  consentGiven    Boolean     @default(false)
  consentGivenAt  DateTime?
  status          String      @default("pending") // pending | approved | rejected
  rewarded        Boolean     @default(false)
  notes           String?     // Admin rejection notes
  submittedAt     DateTime    @default(now())
  reviewedAt      DateTime?
  reviewedBy      String?

  project         DataProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model ActivityLog {
  id          String   @id @default(cuid())
  type        String   // login | logout | register | call_start | call_end | call_error | call_cancel | call_decline | submission | withdrawal_request | call_connecting | call_reconnecting
  userId      String?  // null for system events
  userName    String?
  severity    String   @default("info") // info | warning | error | success
  metadata    String?  // JSON blob with extra details
  ip          String?
  createdAt   DateTime @default(now())
}

model CallSession {
  id              String    @id @default(cuid())
  callCode        String    @unique  // short code shared between users — personal 5-char or generated
  projectId       String?   // null for standalone calls, set for data-project calls
  initiatorId     String    // user id (cuid) of caller
  targetUserCode  String?   // personal call code of the person being called (for dialer mode)
  receiverId      String?   // user id of person who joins
  offer           String?   // JSON: RTCSessionDescription (SDP offer)
  answer          String?   // JSON: RTCSessionDescription (SDP answer)
  initiatorIce    String    @default("[]") // JSON array of RTCIceCandidate from initiator
  receiverIce     String    @default("[]") // JSON array of RTCIceCandidate from receiver
  status          String    @default("waiting") // calling | waiting | active | completed | declined | missed
  callType        String    @default("audio")   // "audio" | "video"
  endedBy         String?   // user id of who ended the call (initiator or receiver)
  endedReason     String?   // reason for ending (user_hangup, remote_hangup, call_timeout, etc)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([targetUserCode, status])
  @@index([initiatorId, status])
}

model CallRecording {
  id                   String   @id @default(cuid())
  callCode             String
  userId               String         // Original recorder (owner of call)
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  duration             Int      // seconds
  fileUrl              String
  fileSize             Int?     // bytes
  callType             String   @default("audio")
  otherName            String?
  callEndedBy          String?  // user ID of whoever ended the call (for auto-share)
  shareFromRecordingId String?  // FK to original recording if this was auto-shared
  sharedRecording      CallRecording? @relation("RecordingShare", fields: [shareFromRecordingId], references: [id], onDelete: SetNull)
  sharedTo             CallRecording[] @relation("RecordingShare")
  createdAt            DateTime @default(now())
}
